{
  "name": "material-shapes-ts",
  "version": "0.3.0",
  "description": "Material Design shapes for the web — all 35 shapes, plus morphing/transitions. Ported from AndroidX Graphics Shapes.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js",
      "default": "./dist/vue/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "lint": "eslint .",
    "test": "node --test test/*.test.js",
    "prepublishOnly": "npm run build",
    "build:demo": "node scripts/build-demo.mjs"
  },
  "keywords": [
    "material",
    "material-design",
    "shapes",
    "morph",
    "svg",
    "clip-path",
    "vue",
    "typescript"
  ],
  "author": "Ruan Spies",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ruanspies/material-shapes-ts.git"
  },
  "bugs": {
    "url": "https://github.com/ruanspies/material-shapes-ts/issues"
  },
  "homepage": "https://github.com/ruanspies/material-shapes-ts#readme",
  "packageManager": "pnpm@10.27.0",
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "esbuild": "^0.28.1",
    "typescript": "^5.7.3",
    "vue": "^3.5.39"
  }
}
